page {
  --color-primary: #52C41A;
  --color-primary-light: #73D13D;
  --color-danger: #FF4D4F;
  --color-danger-bg: #FFF1F0;
  --color-success-bg: #F6FFED;
  --color-bg: #F5F5F5;
  --color-card: #FFFFFF;
  --color-text: #333333;
  --color-text-secondary: #999999;
  --color-text-light: #BFBFBF;
  --color-border: #E8E8E8;
  --radius-lg: 16rpx;
  --radius-md: 12rpx;
  --radius-sm: 8rpx;
  --shadow-card: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);

  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", "PingFang SC",
    "Hiragino Sans GB", "Microsoft YaHei", sans-serif;
  font-size: 28rpx;
  color: var(--color-text);
  background-color: var(--color-bg);
  box-sizing: border-box;
}

/* ===== 通用工具类 ===== */
.flex-center { display: flex; align-items: center; justify-content: center; }
.flex-between { display: flex; align-items: center; justify-content: space-between; }
.flex-col { display: flex; flex-direction: column; }
.text-center { text-align: center; }
.text-right { text-align: right; }
.text-secondary { color: var(--color-text-secondary); }
.text-light { color: var(--color-text-light); }

/* 数字等宽字体 */
.weight-num {
  font-family: "SF Mono", "Menlo", "Consolas", monospace;
  font-weight: 600;
}

/* ===== 卡片容器 ===== */
.card {
  background: var(--color-card);
  border-radius: var(--radius-lg);
  padding: 32rpx;
  margin: 24rpx;
  box-shadow: var(--shadow-card);
}

/* ===== 体重升降颜色 ===== */
.trend-down { color: var(--color-primary); }
.trend-up { color: var(--color-danger); }
.trend-zero { color: var(--color-text-secondary); }
.badge-down {
  background: var(--color-success-bg);
  color: var(--color-primary);
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
}
.badge-up {
  background: var(--color-danger-bg);
  color: var(--color-danger);
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
}

/* ===== 按钮 ===== */
.btn-primary {
  background: var(--color-primary);
  color: #fff;
  border-radius: 48rpx;
  padding: 24rpx 0;
  text-align: center;
  font-size: 32rpx;
  font-weight: 500;
}
.btn-primary:active { opacity: 0.85; }
.btn-outline {
  border: 2rpx solid var(--color-border);
  border-radius: 48rpx;
  padding: 20rpx 0;
  text-align: center;
  font-size: 28rpx;
  color: var(--color-text);
  background: #fff;
}

/* ===== 空状态 ===== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}
.empty-state image { width: 200rpx; height: 200rpx; margin-bottom: 32rpx; }
.empty-state .title { font-size: 32rpx; color: var(--color-text); margin-bottom: 12rpx; }
.empty-state .desc { font-size: 26rpx; color: var(--color-text-secondary); }

/* ===== 加载/同步指示 ===== */
.sync-bar {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 12rpx 0;
  font-size: 22rpx;
  color: var(--color-text-secondary);
}
.sync-bar .dot { margin: 0 4rpx; }
.sync-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: var(--color-primary);
  margin-right: 8rpx;
}
