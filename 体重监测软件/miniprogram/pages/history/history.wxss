.page { min-height: 100vh; padding-bottom: 40rpx; }

/* ===== 搜索栏 ===== */
.search-bar {
  display: flex; align-items: center; justify-content: space-between;
  padding: 24rpx 32rpx; background: #fff;
}
.month-picker { font-size: 30rpx; font-weight: 500; display: flex; align-items: center; gap: 8rpx; }
.arrow { font-size: 20rpx; color: var(--color-text-light); }
.record-count { font-size: 26rpx; }

/* ===== 记录卡片 ===== */
.record-item {
  display: flex; align-items: center;
  padding: 28rpx 32rpx;
}
.record-left { min-width: 160rpx; }
.record-date { font-size: 28rpx; margin-bottom: 4rpx; }
.record-time { font-size: 22rpx; color: var(--color-text-light); }
.record-source { margin-top: 6rpx; }
.source-tag {
  display: inline-block; font-size: 20rpx;
  padding: 2rpx 10rpx; border-radius: 8rpx;
}
.source-tag.auto { background: #E6F7FF; color: #1890FF; }
.source-tag.manual { background: #FFF7E6; color: #FA8C16; }

.record-center { flex: 1; margin-left: 24rpx; }
.record-weight { font-size: 36rpx; }
.record-extras { font-size: 22rpx; color: var(--color-text-secondary); margin-top: 4rpx; }
.record-note { font-size: 22rpx; margin-top: 4rpx; }

.record-right { min-width: 100rpx; text-align: right; }
.record-change { font-size: 26rpx; }
