.page { min-height: 100vh; padding-bottom: 40rpx; }

/* ===== 同步状态栏 ===== */
.sync-bar {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 16rpx 0 0;
  font-size: 22rpx;
  color: var(--color-text-secondary);
}
.sync-dot {
  width: 12rpx; height: 12rpx;
  border-radius: 50%;
  background: var(--color-primary);
  margin-right: 8rpx;
}
.sync-dot.pulse {
  animation: pulse 1.2s ease-in-out infinite;
}
@keyframes pulse {
  0%, 100% { opacity: 1; transform: scale(1); }
  50% { opacity: 0.4; transform: scale(0.8); }
}

/* ===== 未绑定引导 ===== */
.bind-guide {
  text-align: center;
  padding: 80rpx 40rpx;
  margin-top: 80rpx;
}
.bind-icon { font-size: 96rpx; margin-bottom: 32rpx; }
.bind-title { font-size: 36rpx; font-weight: 600; margin-bottom: 16rpx; }
.bind-desc { font-size: 28rpx; color: var(--color-text-secondary); margin-bottom: 48rpx; line-height: 1.6; }
.bind-btn { width: 100%; }

/* ===== 今日体重 Hero ===== */
.hero { text-align: center; padding: 48rpx 32rpx; }
.hero-label { font-size: 28rpx; color: var(--color-text-secondary); margin-bottom: 16rpx; }
.hero-value { margin-bottom: 20rpx; }
.hero-num {
  font-size: 96rpx;
  font-weight: 700;
  line-height: 1;
  color: var(--color-text);
}
.hero-num.muted { color: var(--color-text-light); }
.hero-unit { font-size: 36rpx; color: var(--color-text-secondary); margin-left: 8rpx; }
.hero-change { margin-bottom: 8rpx; }
.change-badge {
  display: inline-flex; align-items: center; gap: 4rpx;
  padding: 8rpx 24rpx; border-radius: 32rpx;
  font-size: 28rpx; font-weight: 500;
}
.change-badge.down { background: var(--color-success-bg); color: var(--color-primary); }
.change-badge.up { background: var(--color-danger-bg); color: var(--color-danger); }
.change-badge.zero { background: #f5f5f5; color: var(--color-text-secondary); }
.change-label { display: block; font-size: 22rpx; color: var(--color-text-secondary); margin-top: 6rpx; }
.hero-hint { font-size: 24rpx; margin-top: 8rpx; }
.hero-empty { margin-bottom: 20rpx; }

/* ===== 身体数据双卡片 ===== */
.body-cards {
  display: flex; gap: 24rpx; margin: 0 24rpx 0;
}
.body-card {
  flex: 1; background: var(--color-card);
  border-radius: var(--radius-lg); padding: 28rpx;
  box-shadow: var(--shadow-card); text-align: center;
}
.body-card-label { font-size: 24rpx; color: var(--color-text-secondary); margin-bottom: 12rpx; }
.body-card-value { font-size: 48rpx; font-weight: 600; margin-bottom: 8rpx; }
.body-card-tag { font-size: 24rpx; }

/* ===== 目标进度 ===== */
.goal-section { margin-top: 24rpx; }
.goal-header { font-size: 28rpx; font-weight: 500; }
.goal-progress-text { font-size: 32rpx; font-weight: 600; color: var(--color-primary); }
.progress-bar {
  height: 12rpx; background: #eee; border-radius: 6rpx;
  margin: 20rpx 0 12rpx; overflow: hidden;
}
.progress-fill {
  height: 100%; background: var(--color-primary);
  border-radius: 6rpx; transition: width 0.3s;
}
.goal-bottom { font-size: 24rpx; }
.goal-remain { color: var(--color-text); font-weight: 500; }

/* ===== 本周摘要 ===== */
.week-summary { margin-top: 24rpx; }
.section-title { font-size: 28rpx; font-weight: 500; margin-bottom: 24rpx; }
.summary-row { display: flex; }
.summary-item { flex: 1; text-align: center; }
.summary-num { font-size: 44rpx; font-weight: 600; margin-bottom: 8rpx; }
.summary-num.muted { color: var(--color-text-light); }
.summary-label { font-size: 24rpx; color: var(--color-text-secondary); }
