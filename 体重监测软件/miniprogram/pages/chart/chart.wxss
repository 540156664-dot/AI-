.page { min-height: 100vh; padding-bottom: 40rpx; }

/* ===== 时间标签 ===== */
.time-tabs {
  display: flex; background: #fff; padding: 16rpx 24rpx;
  position: sticky; top: 0; z-index: 10;
}
.tab-item {
  flex: 1; text-align: center; padding: 16rpx 0;
  font-size: 26rpx; color: var(--color-text-secondary);
  border-radius: 32rpx; margin: 0 4rpx; transition: all 0.2s;
}
.tab-item.active {
  background: var(--color-success-bg);
  color: var(--color-primary); font-weight: 500;
}

/* ===== 图表容器 ===== */
.chart-container { margin-top: 24rpx; padding: 24rpx; }

/* ===== 数据摘要 ===== */
.stats-row { display: flex; margin: 24rpx 24rpx 0; }
.stat-item { flex: 1; text-align: center; }
.stat-value { font-size: 40rpx; font-weight: 600; margin-bottom: 6rpx; }
.stat-label { font-size: 24rpx; color: var(--color-text-secondary); }
