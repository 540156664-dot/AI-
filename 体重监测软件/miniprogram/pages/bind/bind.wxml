<!-- 小米设备绑定 -->
<view class="page">
  <!-- 步骤指示器 -->
  <view class="steps">
    <view class="step {{currentStep >= 1 ? 'active' : ''}}">
      <view class="step-num">1</view>
      <view class="step-label">小米授权</view>
    </view>
    <view class="step-line {{currentStep >= 2 ? 'active' : ''}}"></view>
    <view class="step {{currentStep >= 2 ? 'active' : ''}}">
      <view class="step-num">2</view>
      <view class="step-label">选择设备</view>
    </view>
    <view class="step-line {{currentStep >= 3 ? 'active' : ''}}"></view>
    <view class="step {{currentStep >= 3 ? 'active' : ''}}">
      <view class="step-num">3</view>
      <view class="step-label">完成绑定</view>
    </view>
  </view>

  <!-- Step 1: 小米账号授权 -->
  <view class="step-content" wx:if="{{currentStep === 1}}">
    <view class="card">
      <view class="step-title">授权小米账号</view>
      <view class="step-desc">
        我们需要读取你小米账号下的体脂秤数据。点击下方按钮将跳转到小米官方授权页面。
      </view>

      <view class="auth-notice">
        <view class="notice-icon">🔒</view>
        <view class="notice-text">
          <view class="notice-title">你的数据安全吗？</view>
          <view>我们仅读取体重秤数据，不会获取其他设备信息。你的小米账号密码不会存储在我们的服务器上。</view>
        </view>
      </view>

      <button class="btn-primary auth-btn" bindtap="startXiaomiAuth" loading="{{authLoading}}">
        前往小米授权
      </button>
      <view class="auth-hint">授权后可在设置中随时取消</view>
    </view>
  </view>

  <!-- Step 2: 选择设备 -->
  <view class="step-content" wx:if="{{currentStep === 2}}">
    <view class="card">
      <view class="step-title">选择你的体重秤</view>
      <view class="step-desc">检测到以下小米智能设备，请选择要绑定的体重秤：</view>
    </view>

    <view class="device-list" wx:if="{{devices.length > 0}}">
      <view
        class="device-item card {{selectedDevice === item.id ? 'selected' : ''}}"
        wx:for="{{devices}}"
        wx:key="id"
        bindtap="selectDevice"
        data-id="{{item.id}}"
      >
        <view class="device-icon">⚖️</view>
        <view class="device-info">
          <view class="device-name">{{item.name}}</view>
          <view class="device-model text-secondary">{{item.model}}</view>
        </view>
        <view class="device-check">
          <view class="radio {{selectedDevice === item.id ? 'checked' : ''}}"></view>
        </view>
      </view>
    </view>

    <view class="empty-state" wx:else>
      <view class="title">未发现智能秤设备</view>
      <view class="desc">请确保体脂秤已连接 WiFi 并绑定到当前小米账号</view>
    </view>

    <button
      class="btn-primary"
      wx:if="{{devices.length > 0}}"
      bindtap="confirmDevice"
    >
      确认选择
    </button>
  </view>

  <!-- Step 3: 完成 -->
  <view class="step-content" wx:if="{{currentStep === 3}}">
    <view class="card finish-card">
      <view class="finish-icon">🎉</view>
      <view class="finish-title">绑定成功！</view>
      <view class="finish-device">{{boundDeviceName}}</view>
      <view class="finish-desc">正在同步最近的体重数据，请稍候...</view>
    </view>

    <button class="btn-primary" bindtap="goHome">进入首页</button>
  </view>
</view>
