.page { min-height: 100vh; padding: 32rpx 0; }

/* ===== 步骤指示器 ===== */
.steps {
  display: flex; align-items: center; justify-content: center;
  padding: 32rpx 48rpx; margin-bottom: 24rpx;
}
.step { display: flex; flex-direction: column; align-items: center; }
.step-num {
  width: 56rpx; height: 56rpx; border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  background: #eee; color: var(--color-text-light);
  font-size: 26rpx; font-weight: 600; margin-bottom: 8rpx;
  transition: all 0.3s;
}
.step.active .step-num {
  background: var(--color-primary); color: #fff;
}
.step-label { font-size: 22rpx; color: var(--color-text-light); }
.step.active .step-label { color: var(--color-primary); }
.step-line {
  width: 80rpx; height: 2rpx; background: #eee;
  margin-bottom: 28rpx;
  transition: background 0.3s;
}
.step-line.active { background: var(--color-primary); }

/* ===== 步骤内容 ===== */
.step-content { padding: 0 24rpx; }
.step-title { font-size: 36rpx; font-weight: 600; margin-bottom: 16rpx; }
.step-desc {
  font-size: 28rpx; color: var(--color-text-secondary);
  line-height: 1.6; margin-bottom: 32rpx;
}

/* ===== 安全提示 ===== */
.auth-notice {
  display: flex; background: #F6FFED; border-radius: var(--radius-sm);
  padding: 24rpx; margin-bottom: 40rpx;
}
.notice-icon { font-size: 40rpx; margin-right: 16rpx; }
.notice-title { font-weight: 500; margin-bottom: 4rpx; }
.notice-text { font-size: 24rpx; color: var(--color-text-secondary); line-height: 1.5; flex: 1; }

.auth-btn { width: 100%; margin-bottom: 16rpx; }
.auth-hint { text-align: center; font-size: 24rpx; color: var(--color-text-light); }

/* ===== 设备列表 ===== */
.device-list { margin-bottom: 32rpx; }
.device-item {
  display: flex; align-items: center; padding: 28rpx 32rpx;
  margin-bottom: 16rpx; border: 2rpx solid transparent;
  transition: border-color 0.2s;
}
.device-item.selected { border-color: var(--color-primary); }
.device-icon { font-size: 56rpx; margin-right: 24rpx; }
.device-info { flex: 1; }
.device-name { font-size: 30rpx; font-weight: 500; margin-bottom: 4rpx; }
.device-model { font-size: 24rpx; }
.radio {
  width: 36rpx; height: 36rpx; border-radius: 50%;
  border: 3rpx solid var(--color-border);
  transition: all 0.2s;
}
.radio.checked {
  border-color: var(--color-primary); background: var(--color-primary);
  box-shadow: inset 0 0 0 4rpx #fff;
}

/* ===== 完成页 ===== */
.finish-card { text-align: center; padding: 80rpx 40rpx; }
.finish-icon { font-size: 120rpx; margin-bottom: 32rpx; }
.finish-title { font-size: 40rpx; font-weight: 600; margin-bottom: 12rpx; }
.finish-device { font-size: 28rpx; color: var(--color-primary); margin-bottom: 20rpx; }
.finish-desc { font-size: 26rpx; color: var(--color-text-secondary); }
