<UserControl x:Class="RackUI.MainPalette"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="320">
    <TabControl x:Name="MainTabControl">
        <TabItem Header="货架">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="10" x:Name="RackPanel" />
            </ScrollViewer>
        </TabItem>
        <TabItem Header="输送机">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="10" x:Name="ConveyorPanel" />
            </ScrollViewer>
        </TabItem>
        <TabItem Header="堆垛机">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="10" x:Name="StackerPanel" />
            </ScrollViewer>
        </TabItem>
        <TabItem Header="控制柜">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="10" x:Name="CabinetPanel" />
            </ScrollViewer>
        </TabItem>
        <TabItem Header="围栏">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="10" x:Name="FencePanel" />
            </ScrollViewer>
        </TabItem>
        <TabItem Header="扫码器">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="10" x:Name="ScannerPanel" />
            </ScrollViewer>
        </TabItem>
        <TabItem Header="统计">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="10" x:Name="BOMPanel" />
            </ScrollViewer>
        </TabItem>
        <TabItem Header="设置">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="10" x:Name="SettingsPanel" />
            </ScrollViewer>
        </TabItem>
    </TabControl>
</UserControl>
